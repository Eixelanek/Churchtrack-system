# CORS is set only in apache-cors.conf (Render/Docker) to avoid duplicate
# Access-Control-Allow-Origin values. Do not add CORS here.

# Prevent directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "^(database\.php|\.env|composer\.json|composer\.lock)$">
    Order allow,deny
    Deny from all
</FilesMatch>
