{
  "version": 2,
  "builds": [
    {
      "src": "faithtrack/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "faithtrack/$1"
    }
  ],
  "buildCommand": "cd faithtrack && npm install && npm run build",
  "outputDirectory": "faithtrack/dist",
  "framework": "vite"
}
